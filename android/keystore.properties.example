# Template for android/keystore.properties (create that file locally; it is gitignored and will not exist after clone).
# Expo: eas credentials -p android → Download keystore / copy Keystore password, Key alias, Key password.

storeFile=keystores/@manojchow72__nestiti.jks
# Or: storeFile=../credentials/android/keystore.jks
storePassword=
keyAlias=
keyPassword=

# Confirm SHA1 matches Play Console upload key before uploading AAB:
#   keytool -list -v -keystore keystores/@manojchow72__nestiti.jks -alias YOUR_ALIAS
# (Expected upload cert SHA1 is shown in Play when upload signing mismatches.)
